{
  "version": 2,
  "builds": [
    {
      "src": "login-system-backend/src/app.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "login-system-backend/src/**"
      }
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "login-system-backend/src/app.ts"
    },
    {
      "src": "/",
      "dest": "index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "JWT_SECRET": "@jwt_secret",
    "NODE_ENV": "production"
  }
}
